# MQTT Broker (use the same credentials as the root .env file)
MQTT_BROKER=192.168.1.100
MQTT_PORT=1883
MQTT_USER=your_mqtt_username
MQTT_PASS=your_mqtt_password

# Serial port for LD2420 (after enabling UART on Pi)
SERIAL_PORT=/dev/serial0

# Screen timeout in seconds after presence is lost
SCREEN_TIMEOUT=60

# Distance threshold in cm (0 = ignore distance, turn on for any presence)
DISTANCE_THRESHOLD=50
